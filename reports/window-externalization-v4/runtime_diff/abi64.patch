+static void copy_truncated(char *dst, size_t dst_size, const char *src) {
+    if (dst == nullptr || dst_size == 0) {
+        return;
+    }
+    if (src == nullptr) {
+        dst[0] = '\0';
+        return;
+    }
+    size_t i = 0;
+    for (; i + 1 < dst_size && src[i] != '\0'; ++i) {
+        dst[i] = src[i];
+    }
+    dst[i] = '\0';
+}
+
+static void orch_record_fatal_detail(
+    PTO2OrchestratorState *orch, int32_t error_code, const char *func, const char *message, int32_t tensor_count = -1,
+    int32_t scalar_count = -1
+) {
+    if (orch == nullptr || orch->sm_header == nullptr || error_code == PTO2_ERROR_NONE) {
+        return;
+    }
+    int32_t expected = PTO2_ERROR_NONE;
+    if (!orch->sm_header->orch_error_detail_code.compare_exchange_strong(
+            expected, error_code, std::memory_order_acq_rel
+        )) {
+        return;
+    }
+    orch->sm_header->orch_error_tensor_count = tensor_count;
+    orch->sm_header->orch_error_scalar_count = scalar_count;
+    copy_truncated(orch->sm_header->orch_error_func, sizeof(orch->sm_header->orch_error_func), func);
+    copy_truncated(orch->sm_header->orch_error_message, sizeof(orch->sm_header->orch_error_message), message);
+}
